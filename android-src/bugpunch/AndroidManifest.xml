<?xml version="1.0" encoding="utf-8"?>
<!--
  Manifest additions for the Bugpunch native recorder. Unity merges this
  into the final app manifest at build time.

  Required for MediaProjection screen capture on Android 10+.
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
          package="au.com.oddgames.bugpunch">

    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PROJECTION" />
    <!-- Android 13+ requires runtime permission for notifications; the
         MediaProjection foreground service posts one. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application>
        <!--
          Manifest-declared ContentProvider that runs before Application.onCreate()
          returns. Reads bugpunch_config.json from APK assets (written at Unity
          build time by BugpunchConfigBundle) and triggers native early init
          (signal handlers, log ring, crash drain) before Unity boots. Same
          pattern Firebase / Sentry / Crashlytics use for their early hooks.
          initOrder="200" runs us ahead of common third-party init providers.
        -->
        <provider
            android:name="au.com.oddgames.bugpunch.BugpunchInitProvider"
            android:authorities="${applicationId}.bugpunchinit"
            android:exported="false"
            android:initOrder="200" />

        <activity
            android:name="au.com.oddgames.bugpunch.BugpunchProjectionRequest"
            android:theme="@android:style/Theme.Translucent.NoTitleBar"
            android:exported="false"
            android:excludeFromRecents="true" />

        <activity
            android:name="au.com.oddgames.bugpunch.BugpunchCrashActivity"
            android:theme="@android:style/Theme.Translucent.NoTitleBar"
            android:exported="false"
            android:excludeFromRecents="true"
            android:screenOrientation="unspecified"
            android:configChanges="orientation|screenSize|keyboardHidden" />

        <activity
            android:name="au.com.oddgames.bugpunch.BugpunchReportActivity"
            android:theme="@android:style/Theme.Translucent.NoTitleBar"
            android:exported="false"
            android:excludeFromRecents="true"
            android:screenOrientation="unspecified"
            android:configChanges="orientation|screenSize|keyboardHidden"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name="au.com.oddgames.bugpunch.BugpunchAnnotateActivity"
            android:theme="@android:style/Theme.Translucent.NoTitleBar"
            android:exported="false"
            android:excludeFromRecents="true"
            android:screenOrientation="unspecified"
            android:configChanges="orientation|screenSize|keyboardHidden" />

        <activity
            android:name="au.com.oddgames.bugpunch.BugpunchToolsActivity"
            android:theme="@android:style/Theme.Translucent.NoTitleBar"
            android:exported="false"
            android:excludeFromRecents="true"
            android:screenOrientation="unspecified"
            android:configChanges="orientation|screenSize|keyboardHidden" />

        <service
            android:name="au.com.oddgames.bugpunch.BugpunchProjectionService"
            android:foregroundServiceType="mediaProjection"
            android:exported="false" />
    </application>
</manifest>
