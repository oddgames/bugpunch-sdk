<linker>
  <!-- The WebRTC streamer (optional ODDGames.BugpunchSdk.WebRTC assembly) no
       longer needs a preserve here: it self-registers via a
       RuntimeInitializeOnLoadMethod (WebRTCStreamerBootstrap), which is an IL2CPP
       linker root, so the streamer survives AOT stripping on its own. com.unity.webrtc
       ships its own link.xml for the Unity.WebRTC runtime itself. -->

  <!-- Preserve [Watch] attribute and enum so IL2CPP doesn't strip them off
       user fields. Without this, declared-watch discovery silently finds nothing. -->
  <assembly fullname="ODDGames.Bugpunch">
    <type fullname="WatchAttribute" preserve="all"/>
    <type fullname="WatchOwner" preserve="all"/>
  </assembly>
</linker>
